#!/bin/bash
# SMMA Clawdbot Skill Wrapper

# Check if running through Clawdbot
SKILL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Check for GetLate API key
if [ -z "$GETLATE_API_KEY" ]; then
    echo "Error: GETLATE_API_KEY environment variable not set"
    echo ""
    echo "To set it up:"
    echo "1. Get your API key from https://getlate.dev"
    echo "2. Add to your shell configuration:"
    echo "   export GETLATE_API_KEY='your_api_key_here'"
    echo ""
    echo "Or run the setup script:"
    echo "   $SKILL_DIR/setup.sh"
    exit 1
fi

# Try to run with system Python first
python3 "$SKILL_DIR/smma.py" "$@" 2>/dev/null

# If that fails, check for missing dependencies
if [ $? -ne 0 ]; then
    echo "Checking dependencies..."
    
    # Test imports
    python3 -c "import requests, click, rich, tabulate" 2>/dev/null
    if [ $? -ne 0 ]; then
        echo ""
        echo "Missing Python dependencies. To install:"
        echo ""
        echo "Option 1 - Using pipx (recommended):"
        echo "  pipx install python-dotenv"
        echo "  pipx install requests"
        echo "  pipx install click"
        echo "  pipx install rich"
        echo "  pipx install tabulate"
        echo ""
        echo "Option 2 - Using apt:"
        echo "  sudo apt install python3-requests python3-click python3-rich python3-tabulate"
        echo ""
        echo "Option 3 - Using pip with override (not recommended):"
        echo "  pip install --break-system-packages python-dotenv requests click rich tabulate"
        echo ""
        exit 1
    fi
    
    # If dependencies are OK but still failing, show the actual error
    python3 "$SKILL_DIR/smma.py" "$@"
fi