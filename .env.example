# GetLate API Configuration
# Get your API key from https://getlate.dev
GETLATE_API_KEY=your_getlate_api_key_here

# Optional: Timezone for scheduling (default: UTC)
# TIMEZONE=America/New_York

# Optional: Default platforms for posting
# DEFAULT_PLATFORMS=twitter,instagram,linkedin

# Optional: Media upload directory
# MEDIA_DIR=./media

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Optional: Health monitoring settings
# MONITOR_INTERVAL=7200  # 2 hours in seconds
# MAX_RECOVERY_ATTEMPTS=3

# Optional: Docker sandbox settings
# ENABLE_SANDBOX=false
# SANDBOX_MEMORY_LIMIT=512m
# SANDBOX_CPU_LIMIT=0.5

# Optional: Notification settings (for alerts)
# NOTIFICATION_EMAIL=
# NOTIFICATION_WEBHOOK=

# Optional: Database for analytics (if using local storage)
# DATABASE_URL=sqlite:///analytics.db

# Optional: Proxy settings (if behind corporate firewall)
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=localhost,127.0.0.1

# Optional: Custom API endpoints (for self-hosted GetLate)
# GETLATE_API_URL=https://getlate.dev/api/v1

# Optional: Rate limiting
# RATE_LIMIT_REQUESTS=60
# RATE_LIMIT_PERIOD=60  # seconds