#!/usr/bin/env bash
# gateway-watchdog.sh — Health check + auto-restart for clawdbot-gateway
# Copy to ~/.clawdbot/scripts/gateway-watchdog.sh
# Make executable: chmod +x ~/.clawdbot/scripts/gateway-watchdog.sh
# Triggered by clawdbot-watchdog.timer every 5 minutes.

set -euo pipefail

LOGFILE="/root/.clawdbot/logs/watchdog.log"
COOLDOWN_FILE="/root/.clawdbot/logs/.watchdog-last-restart"
COOLDOWN_SECONDS=60
HEALTH_TIMEOUT=15

log() {
  echo "$(date -u '+%Y-%m-%dT%H:%M:%SZ') $*" >> "$LOGFILE"
}

# Check cooldown — skip restart if we restarted recently
check_cooldown() {
  if [[ -f "$COOLDOWN_FILE" ]]; then
    last_restart=$(cat "$COOLDOWN_FILE")
    now=$(date +%s)
    elapsed=$(( now - last_restart ))
    if (( elapsed < COOLDOWN_SECONDS )); then
      log "COOLDOWN: skipping restart, last restart was ${elapsed}s ago (< ${COOLDOWN_SECONDS}s)"
      return 1
    fi
  fi
  return 0
}

do_restart() {
  local reason="$1"
  log "RESTART: reason='${reason}', restarting clawdbot-gateway"
  date +%s > "$COOLDOWN_FILE"
  systemctl --user restart clawdbot-gateway
  log "RESTART: systemctl restart issued"
}

# Run health check with timeout
health_rc=0
timeout "$HEALTH_TIMEOUT" clawdbot gateway health >/dev/null 2>&1 || health_rc=$?

if (( health_rc == 0 )); then
  # Healthy — nothing to do
  exit 0
fi

# Health check failed (timeout exits 124, otherwise the command's own exit code)
reason="health check failed (exit code ${health_rc}, timeout=${HEALTH_TIMEOUT}s)"
log "UNHEALTHY: ${reason}"

if check_cooldown; then
  do_restart "$reason"
else
  log "SKIPPED: restart suppressed by cooldown"
fi
